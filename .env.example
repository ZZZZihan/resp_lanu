RESP_LANU_PROFILE=pi-offline
RESP_LANU_BIND_HOST=0.0.0.0
RESP_LANU_BIND_PORT=8000

# Required for LAN deployment. Do not use the built-in development defaults.
RESP_LANU_ADMIN_TOKEN=change-me
RESP_LANU_SESSION_SECRET=change-me-too

RESP_LANU_MODEL_DIR=models/vosk-model-small-cn-0.22
RESP_LANU_DIALOGUE_PROVIDER=rule-based
RESP_LANU_TTS_PROVIDER=espeak
RESP_LANU_ENABLE_TTS=true
RESP_LANU_RECORDING_DEVICE=
RESP_LANU_PLAY_ASSISTANT_AUDIO_ON_SERVER=false
RESP_LANU_EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
RESP_LANU_AUDIO_PLAYER_BINARY=pw-play
RESP_LANU_AUDIO_PLAYER_ARGS=
RESP_LANU_MAX_UPLOAD_BYTES=26214400
RESP_LANU_GENERATE_FEATURE_ARTIFACTS=false

# RESP_LANU_OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# RESP_LANU_OPENAI_API_KEY=sk-local
# RESP_LANU_OPENAI_MODEL=qwen2.5

# Pi5 connected mode: MiMo handles ordinary dialogue and ZeroClaw handles
# tools, memory, agents, hardware actions, and long-running daemon requests.
# RESP_LANU_PROFILE=pi-connected
# RESP_LANU_DIALOGUE_PROVIDER=mimo-router
# RESP_LANU_OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
# RESP_LANU_OPENAI_API_KEY=tp-example
# RESP_LANU_OPENAI_MODEL=mimo-v2.5
# RESP_LANU_ZEROCLAW_BINARY=/home/pi/zeroclaw/zeroclaw
# RESP_LANU_ZEROCLAW_WORKING_DIR=/home/pi/zeroclaw
# RESP_LANU_ZEROCLAW_PROVIDER=custom:https://token-plan-cn.xiaomimimo.com/v1
# RESP_LANU_ZEROCLAW_MODEL=mimo-v2.5
# RESP_LANU_ZEROCLAW_API_KEY=tp-example
# RESP_LANU_ZEROCLAW_TIMEOUT_SECONDS=90
# RESP_LANU_RECORDING_DEVICE=plughw:CARD=Device,DEV=0
# RESP_LANU_TTS_PROVIDER=edge-tts
# RESP_LANU_ENABLE_TTS=true
# RESP_LANU_PLAY_ASSISTANT_AUDIO_ON_SERVER=true
# HDMI output example:
# RESP_LANU_AUDIO_PLAYER_BINARY=aplay
# RESP_LANU_AUDIO_PLAYER_ARGS=-D plughw:CARD=vc4hdmi1,DEV=0
