RESP_LANU_PROFILE=pi-offline
RESP_LANU_BIND_HOST=0.0.0.0
RESP_LANU_BIND_PORT=8000

# Required for LAN deployment. Do not use the built-in development defaults.
RESP_LANU_ADMIN_TOKEN=change-me
RESP_LANU_SESSION_SECRET=change-me-too

RESP_LANU_MODEL_DIR=models/vosk-model-small-cn-0.22
RESP_LANU_DIALOGUE_PROVIDER=rule-based
RESP_LANU_TTS_PROVIDER=espeak
RESP_LANU_ENABLE_TTS=true
RESP_LANU_MAX_UPLOAD_BYTES=26214400
RESP_LANU_GENERATE_FEATURE_ARTIFACTS=false

# RESP_LANU_OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# RESP_LANU_OPENAI_API_KEY=sk-local
